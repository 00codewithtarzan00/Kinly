rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Check if user is a member of the specific family
    function isFamilyMember(familyId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    // --- Collection: Users ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == resource.data.familyId);
      allow list: if isSignedIn() && resource.data.familyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
      
      allow create: if isSignedIn() && request.auth.uid == uid && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == uid && isValidUser(incoming()) && (
        // Only allow updating specific fields, but not familyId if it's already set (to prevent hopping)
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) && incoming().familyId == existing().familyId) ||
        // Allow setting familyId if it was null
        (existing().familyId == null && incoming().diff(existing()).affectedKeys().hasOnly(['familyId', 'updatedAt']))
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'familyId']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.familyId == null || (data.familyId is string && data.familyId.size() == 6)) &&
             data.updatedAt == request.time;
    }

    // --- Collection: Families ---
    match /families/{familyId} {
      allow get: if isFamilyMember(familyId);
      allow create: if isSignedIn() && isValidFamily(incoming());
      // No updates for now to keep it simple, or only by member
      allow update: if isFamilyMember(familyId) && isValidFamily(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']);
    }

    function isValidFamily(data) {
      return data.keys().hasAll(['familyId', 'name', 'createdAt']) &&
             data.familyId is string && data.familyId.size() == 6 &&
             data.name is string && data.name.size() <= 100 &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    // --- Sub-collections under Families ---
    match /families/{familyId}/{collection=**} {
       // Root gate for all sub-resources
       allow read, write: if isFamilyMember(familyId);
    }

    match /families/{familyId}/posts/{postId} {
      allow create: if isFamilyMember(familyId) && isValidPost(incoming());
      allow delete: if isFamilyMember(familyId) && (existing().authorId == request.auth.uid);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'timestamp']) &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.content is string && data.content.size() <= 1000 &&
             data.timestamp == request.time &&
             (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    match /families/{familyId}/tasks/{taskId} {
      allow create: if isFamilyMember(familyId) && isValidTask(incoming());
      allow update: if isFamilyMember(familyId) && isValidTask(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isCompleted', 'assignedTo'])
      );
      allow delete: if isFamilyMember(familyId);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['taskName', 'isCompleted', 'createdBy', 'createdAt']) &&
             data.taskName is string && data.taskName.size() <= 200 &&
             data.isCompleted is bool &&
             data.createdBy is string &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    match /families/{familyId}/vault/{vaultId} {
      allow create, update: if isFamilyMember(familyId) && isValidVaultItem(incoming());
      allow delete: if isFamilyMember(familyId);
    }

    function isValidVaultItem(data) {
      return data.keys().hasAll(['title', 'value', 'updatedBy', 'updatedAt']) &&
             data.title is string && data.title.size() <= 100 &&
             data.value is string && data.value.size() <= 1000 &&
             data.updatedBy == request.auth.uid &&
             data.updatedAt == request.time;
    }
  }
}
