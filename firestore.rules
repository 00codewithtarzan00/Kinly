rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Efficient Relational Identity Helper
    function isMemberOf(familyId) {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(path) && get(path).data.get('familyId', null) == familyId;
    }

    function isFamilyHead(familyId) {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = exists(path) ? get(path).data : {};
      return isSignedIn() && 
             userData.get('familyId', null) == familyId && 
             userData.get('isHead', false) == true;
    }

    // --- Collection: Users ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        request.auth.uid == uid || 
        isFamilyHead(existing().get('familyId', 'none'))
      );
      allow delete: if isSignedIn() && request.auth.uid == uid;

      // Personal identifiers/nicknames
      match /memberAliases/{targetUid} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // --- Collection: Families ---
    match /families/{familyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isMemberOf(familyId) ||
        existing().get('headId', null) == null
      );
    }

    // --- Sub-collections under Families (Wall, Tasks, Vault) ---
    
    match /families/{familyId}/posts/{postId} {
      allow read: if isMemberOf(familyId);
      allow create: if isMemberOf(familyId) && (isSystemNotification(incoming()) || isValidPost(incoming()));
      allow delete: if isMemberOf(familyId) && (existing().authorId == request.auth.uid || isFamilyHead(familyId));
    }

    function isSystemNotification(data) {
      return data.get('authorId', null) == 'system';
    }

    function isValidPost(data) {
      let isCreate = resource == null;
      let hasRequired = !isCreate || data.keys().hasAll(['authorId', 'authorName', 'content', 'timestamp']);
      
      return hasRequired &&
             (!data.keys().contains('authorId') || data.authorId == request.auth.uid) &&
             (!data.keys().contains('content') || (data.content is string && data.content.size() <= 5000)) &&
             (!data.keys().contains('timestamp') || data.timestamp == request.time);
    }

    match /families/{familyId}/tasks/{taskId} {
      allow read: if isMemberOf(familyId);
      allow create: if isMemberOf(familyId) && isValidTask(incoming());
      allow update: if isMemberOf(familyId) && (
        // Allow updating deadlineNotified independently or with status
        (incoming().diff(existing()).affectedKeys().hasOnly(['deadlineNotified'])) ||
        (incoming().diff(existing()).affectedKeys().hasAny(['deadlineNotified', 'isCompleted', 'completedById', 'completedByName'])) ||
        isValidTask(incoming())
      );
      allow delete: if isMemberOf(familyId) && existing().createdBy == request.auth.uid;
    }

    function isValidTask(data) {
      let isCreate = resource == null;
      let hasRequired = !isCreate || data.keys().hasAll(['taskName', 'isCompleted', 'createdAt', 'createdBy']);
      
      return hasRequired &&
             (!data.keys().contains('taskName') || (data.taskName is string && data.taskName.size() <= 500)) &&
             (!data.keys().contains('isCompleted') || data.isCompleted is bool) &&
             (!data.keys().contains('createdBy') || data.createdBy == (isCreate ? request.auth.uid : existing().createdBy)) &&
             (!data.keys().contains('assignedId') || data.assignedId == null || data.assignedId is string) &&
             (!data.keys().contains('assignedName') || data.assignedName == null || data.assignedName is string) &&
             (!data.keys().contains('deadline') || data.deadline == null || data.deadline is timestamp) &&
             (!data.keys().contains('deadlineNotified') || data.deadlineNotified is bool) &&
             (!data.keys().contains('createdAt') || data.createdAt == (isCreate ? request.time : existing().get('createdAt', request.time))) &&
             (!data.keys().contains('updatedAt') || data.updatedAt == request.time);
    }

    match /families/{familyId}/vault/{vaultId} {
      allow read: if isMemberOf(familyId);
      allow create, update: if isMemberOf(familyId) && isValidVaultItem(incoming());
      allow delete: if isMemberOf(familyId);
    }

    function isValidVaultItem(data) {
      let isCreate = resource == null;
      let hasRequired = !isCreate || data.keys().hasAll(['title', 'value', 'updatedBy', 'updatedAt']);
      
      return hasRequired &&
             (!data.keys().contains('title') || (data.title is string && data.title.size() <= 200)) &&
             (!data.keys().contains('value') || (data.value is string && data.value.size() <= 5000)) &&
             (!data.keys().contains('updatedBy') || data.updatedBy == request.auth.uid) &&
             (!data.keys().contains('updatedAt') || data.updatedAt == request.time);
    }
  }
}
